{
  "name": "kiya-agent",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:web",
    "build:web": "tsc -b && vite build",
    "build:desktop": "npm run build:web && npm run prepare:tauri-resources",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepare:tauri-resources": "node ./scripts/prepare-tauri-resources.mjs",
    "clean:tauri": "node ./scripts/clean-tauri-target.mjs",
    "package:windows": "node ./scripts/with-stable-build-env.mjs -- npm run tauri build -- --bundles nsis",
    "package:windows-msi": "node ./scripts/with-stable-build-env.mjs -- npm run tauri build -- --bundles msi",
    "check": "tsc -b --noEmit",
    "test": "vitest run",
    "tauri": "node ./scripts/with-stable-build-env.mjs -- tauri"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "@tauri-apps/plugin-store": "^2.4.0",
    "artplayer": "^5.2.6",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.3.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.0.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tauri-apps/cli": "^2.8.0",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
