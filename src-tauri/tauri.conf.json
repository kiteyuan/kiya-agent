{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kiya Agent",
  "version": "0.1.0",
  "identifier": "info.kiteyuan.kiyaagent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:desktop",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kiya Agent",
        "width": 1400,
        "height": 920,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "resources": ["resources/**/*"],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
